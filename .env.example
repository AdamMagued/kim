# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
DEEPSEEK_API_KEY=sk-...

# OpenAI-compatible providers (set openai_base_url in config.yaml to activate)
CEREBRAS_API_KEY=
GROQ_API_KEY=

# Relay Server (set on the cloud host AND in your local .env)
RELAY_PC_API_KEY=your-secret-pc-key
RELAY_PHONE_API_KEY=your-secret-phone-key
RELAY_URL=https://your-relay.railway.app

# Relay Server tuning (optional)
# RELAY_DB_PATH=/app/data/relay.db   # default in Docker
# STALE_PENDING_S=300                # expire un-picked tasks after 5 min
# STALE_RUNNING_S=600                # expire stuck running tasks after 10 min
# PC_TIMEOUT_S=15                    # seconds before PC is considered offline

# Kim Config (overrides config.yaml)
PROJECT_ROOT=E:\kim
ACTIVE_PROVIDER=claude
